generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  name      String   @default("Me")
  avatar    String?
  createdAt DateTime @default(now())
}

model Section {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("general")
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  pages     Page[]
  dailyBalances DailyBalance[]
  emailEvents   EmailEvent[]
}

model Page {
  id        String    @id @default(cuid())
  title     String
  content   String    @default("")
  status    String    @default("active")
  icon      String?                        // ← thêm
  pnl       Float?
  amount    Float?
  category  String?
  metadata  String?                        // ← thêm (JSON string)
  sectionId String
  section   Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tags      PageTag[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  color String    @default("#888")
  pages PageTag[]
}

model PageTag {
  pageId String
  tagId  String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([pageId, tagId])
}

model DailyBalance {
  id         String   @id @default(cuid())
  sectionId  String
  section    Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  date       String
  money1     Float    @default(0)
  money2     Float    @default(0)
  total      Float    @default(0)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailEvent {
  id          String   @id @default(cuid())
  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  email       String
  exchange    String
  eventCode   String
  eventName   String?
  amount      Float?
  status      String   @default("pending")
  eventDate   String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Campaign {
  id          String            @id @default(cuid())
  name        String
  exchange    String
  description String?
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime          @default(now())
  tiers       CampaignTier[]
  accounts    CampaignAccount[]
}

model CampaignTier {
  id             String   @id @default(cuid())
  campaignId     String
  label          String?
  minDeposit     Float
  requiredVolume Float
  holdTime       Int
  bonus          Float
  maxSlots       Int?
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignAccount {
  id          String    @id @default(cuid())
  campaignId  String
  email       String
  uid         String
  wallet      String
  deposit     Float     @default(0)
  depositTime DateTime?
  volume      Float     @default(0)
  note        String?
  createdAt   DateTime  @default(now())
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}